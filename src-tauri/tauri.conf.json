{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "חנות תוספים לאוצריא - אופליין",
  "version": "1.0.6",
  "identifier": "org.otzaria.pluginsoffline",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "חנות תוספים לאוצריא - אופליין",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
